# 后端 API 基础地址，开发时可配代理或直连
VITE_API_BASE_URL=/api

# ---------- Casdoor（casdoor-js-sdk / casdoor-react-sdk）----------
# 四项必填，与 Casdoor 控制台应用配置一致
VITE_CASDOOR_SERVER_URL=https://door.example.com
VITE_CASDOOR_CLIENT_ID=your-client-id
VITE_CASDOOR_APP_NAME=your-app-name
VITE_CASDOOR_ORGANIZATION_NAME=your-org-name
# 可选：OAuth 回调路径，需与 Casdoor 应用 Redirect URLs 一致
# VITE_CASDOOR_REDIRECT_PATH=/callback
# 可选：换 token 接口路径（相对 serverUrl）
# VITE_CASDOOR_SIGNIN_PATH=/api/signin
# VITE_CASDOOR_SCOPE=openid profile email
